# --------------------------------------------------------------------------
# apps/web environment configuration
#
# Copy to apps/web/.env.local for local development. On Vercel / Render /
# any production host, set the same variables in the host's secrets UI —
# .env files are never committed and never deployed.
# --------------------------------------------------------------------------

# Anthropic API key. Server-side only. Required for /api/assessments/generate
# and the /assessments page. Without it the route returns a structured 503
# config error and the UI shows an actionable message.
#
# Demo deployments: a single project-scoped key with the Anthropic monthly
# budget capped is fine. Operator deployments: per-operator keys provisioned
# during Phase 2.
ANTHROPIC_API_KEY=sk-ant-api03-...

# --------------------------------------------------------------------------
# API wiring
# --------------------------------------------------------------------------
# Server-only base URL of @dnca/api. Unset = web renders from @dnca/domain
# fixtures (useful for CI, Vercel preview without a backend).
# API_BASE_URL=http://localhost:3001

# Server-only operator UUID used when WorkOS is NOT configured. The web
# forwards this as `x-demo-operator-id` so the API can scope the request
# in dev mode. Mutually exclusive with WorkOS: when both are set, WorkOS
# wins for signed-in users.
# DEMO_OPERATOR_ID=22222222-2222-2222-2222-222222222222

# --------------------------------------------------------------------------
# WorkOS AuthKit (ADR 0008)
#
# All four below required to enable WorkOS sign-in. Unset = the web runs
# in demo mode: middleware is a no-op, /login is a 404, the header shows
# a "Demo mode" pill, and the API client falls back to x-demo-operator-id
# (or fixtures).
#
# WORKOS_API_KEY and WORKOS_CLIENT_ID come from your WorkOS dashboard.
# WORKOS_COOKIE_PASSWORD must be >= 32 chars; generate with
#   openssl rand -base64 32
# Configure the redirect URI in the WorkOS dashboard to match exactly.
# --------------------------------------------------------------------------
# WORKOS_API_KEY=sk_test_...
# WORKOS_CLIENT_ID=client_01...
# WORKOS_COOKIE_PASSWORD=...32+ char secret...
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Optional. Override for the platform brand name in PDF exports + page
# titles. Defaults to "DN Consultancy Aviation" if unset.
# DNCA_BRAND_NAME="DN Consultancy Aviation"

# Optional. Set to a fixed ISO date (e.g. 2026-05-24) for deterministic
# demo screenshots; everything that uses `new Date()` will continue to use
# the current wall clock if this is unset. Wire-up TBD.
# DEMO_AS_OF_DATE=
